      "default": 0.4,
      "range": [0.1, 2],
      "unit": "mm",
      "section": "Expert Mode - Braille Dot Adjustments",
      "subsection": "Embossing Braille Dot Dimensions (Cone Shape)",
      "description": "Cone dot flat hat diameter"
    },
    {
