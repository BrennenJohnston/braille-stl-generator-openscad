{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenSCAD to Web API Parameter Mapping",
  "description": "Machine-readable mapping between OpenSCAD customizer variables and web API parameters. Source of truth for cross-platform validation.",
  "version": "2.1.0",
  "last_updated": "2026-01-10",
  "documentation": "See PARAMETER_MAPPING.md for human-readable version",
  
  "ui_parameter_format": {
    "description": "OpenSCAD Customizer dropdown format guidelines to prevent duplicate options",
    "correct_format": "param = \"DefaultLabel\"; // [Label1, Label2, Label3]",
    "guidelines": [
      "Use human-readable labels directly as values (e.g., 'Rounded' not 'rounded:Rounded')",
      "The default value must exactly match one of the dropdown options",
      "Avoid value:Label format as it can cause duplicate entries in some OpenSCAD versions",
      "For test system compatibility, normalize both UI labels and lowercase values in calculated section"
    ],
    "test_system_note": "Test system passes parameters via -D flags with lowercase values (e.g., 'rounded', 'positive'). The OpenSCAD file normalizes these to work with UI labels."
  },
  
  "parameters": [
    {
      "openscad_name": "Line_1",
      "web_api_name": "line1",
      "web_ui_label": "Line 1",
      "type": "string",
      "default": "⠓⠑⠇⠇⠕",
      "section": "Text Input - Pre-Translated Braille",
      "description": "First line of braille text (Unicode braille characters)",
      "validation": {
        "pattern": "^[\\u2800-\\u28FF]*$",
        "max_length": 20
      }
    },
    {
      "openscad_name": "Line_2",
      "web_api_name": "line2",
      "web_ui_label": "Line 2",
      "type": "string",
      "default": "⠺⠕⠗⠇⠙",
      "section": "Text Input - Pre-Translated Braille",
      "description": "Second line of braille text"
    },
    {
      "openscad_name": "Line_3",
      "web_api_name": "line3",
      "web_ui_label": "Line 3",
      "type": "string",
      "default": "",
      "section": "Text Input - Pre-Translated Braille",
      "description": "Third line of braille text"
    },
    {
      "openscad_name": "Line_4",
      "web_api_name": "line4",
      "web_ui_label": "Line 4",
      "type": "string",
      "default": "",
      "section": "Text Input - Pre-Translated Braille",
      "description": "Fourth line of braille text"
    },
    {
      "openscad_name": "plate_type",
      "web_api_name": "plate_type",
      "web_ui_label": "Select Plate to Generate",
      "type": "enum",
      "default": "Embossing Plate",
      "values": ["Embossing Plate", "Counter Plate"],
      "test_system_values": ["positive", "negative"],
      "value_mapping": {
        "positive": "Embossing Plate",
        "negative": "Counter Plate",
        "Embossing Plate": "Embossing Plate",
        "Counter Plate": "Counter Plate"
      },
      "section": "Plate Selection",
      "description": "Which plate to generate"
    },
    {
      "openscad_name": "paper_thickness_preset",
      "web_api_name": "paper_thickness_preset",
      "web_ui_label": "Card Thickness",
      "type": "enum",
      "default": "0.4mm",
      "values": ["0.4mm", "0.3mm", "Custom"],
      "section": "Paper Thickness Preset",
      "description": "Preset that controls multiple parameters (spacing, dot dimensions, cylinder settings)",
      "note": "Web UI label is 'Card Thickness' but this is NOT the removed card-geometry feature—it's a parametric memory system"
    },
    {
      "openscad_name": "dot_shape",
      "openscad_test_name": "combined_shape",
      "web_api_name": "combined_shape",
      "web_ui_label": "Braille Dot Shape",
      "type": "enum",
      "default": "Rounded",
      "values": ["Rounded", "Cone"],
      "test_system_values": ["rounded", "cone"],
      "value_mapping": {
        "rounded": "Rounded",
        "cone": "Cone",
        "Rounded": "Rounded",
        "Cone": "Cone"
      },
      "section": "Expert Mode - Shape Selection",
      "description": "Braille dot shape for both emboss and counter plates"
    },
    {
      "openscad_name": "indicators",
      "openscad_test_name": "indicator_shapes",
      "web_api_name": "indicator_shapes",
      "web_ui_label": "Indicator Shapes",
      "type": "enum",
      "default": "On",
      "values": ["On", "Off"],
      "test_system_values": ["on", "off"],
      "value_mapping": {
        "on": "On",
        "off": "Off",
        "On": "On",
        "Off": "Off"
      },
      "section": "Expert Mode - Shape Selection",
      "description": "Row start/end markers"
    },
    {
      "openscad_name": "cylinder_diameter_mm",
      "web_api_name": "cylinder_diameter_mm",
      "web_ui_label": "Cylinder Diameter",
      "type": "float",
      "default": 30.8,
      "range": [10, 100],
      "unit": "mm",
      "section": "Expert Mode - Cylinder Dimensions",
      "description": "Cylinder outer diameter in millimeters"
    },
    {
      "openscad_name": "cylinder_height_mm",
      "web_api_name": "cylinder_height_mm",
      "web_ui_label": "Cylinder Height",
      "type": "float",
      "default": 52.0,
      "range": [20, 150],
      "unit": "mm",
      "section": "Expert Mode - Cylinder Dimensions",
      "description": "Cylinder height in millimeters"
    },
    {
      "openscad_name": "polygon_cutout_radius_mm",
      "web_api_name": "polygon_cutout_radius_mm",
      "web_ui_label": "Cutout Radius",
      "type": "float",
      "default": 13.0,
      "range": [0, 50],
      "unit": "mm",
      "section": "Expert Mode - Cylinder Dimensions",
      "description": "Polygonal cutout circumscribed radius (0 = no cutout)"
    },
    {
      "openscad_name": "polygon_cutout_points",
      "web_api_name": "polygon_cutout_points",
      "web_ui_label": "Cutout Points/Sides",
      "type": "integer",
      "default": 12,
      "range": [3, 24],
      "section": "Expert Mode - Cylinder Dimensions",
      "description": "Number of sides/points for polygonal cutout"
    },
    {
      "openscad_name": "seam_offset_degrees",
      "web_api_name": "seam_offset_degrees",
      "web_ui_label": "Seam Offset",
      "type": "float",
      "default": 0.0,
      "range": [0, 360],
      "unit": "degrees",
      "section": "Expert Mode - Cylinder Dimensions",
      "description": "Seam offset (degrees) — Rotates starting position around cylinder"
    },
    {
      "openscad_name": "grid_columns",
      "web_api_name": "grid_columns",
      "web_ui_label": "Number of Braille Cells",
      "type": "integer",
      "default": 11,
      "range": [1, 20],
      "section": "Expert Mode - Braille Spacing",
      "description": "Number of braille cells per row available for text (2 cells reserved for indicators when On)"
    },
    {
      "openscad_name": "grid_rows",
      "web_api_name": "grid_rows",
      "web_ui_label": "Number of Braille Lines",
      "type": "integer",
      "default": 4,
      "range": [1, 10],
      "section": "Expert Mode - Braille Spacing",
      "description": "Number of lines of braille"
    },
    {
      "openscad_name": "cell_spacing",
      "web_api_name": "cell_spacing",
      "web_ui_label": "Braille Cell Spacing",
      "type": "float",
      "default": 6.5,
      "range": [2, 15],
      "unit": "mm",
      "section": "Expert Mode - Braille Spacing",
      "description": "Horizontal spacing between cells"
    },
    {
      "openscad_name": "line_spacing",
      "web_api_name": "line_spacing",
      "web_ui_label": "Braille Line Spacing",
      "type": "float",
      "default": 10.0,
      "range": [5, 25],
      "unit": "mm",
      "section": "Expert Mode - Braille Spacing",
      "description": "Vertical spacing between lines"
    },
    {
      "openscad_name": "dot_spacing",
      "web_api_name": "dot_spacing",
      "web_ui_label": "Braille Dot Spacing",
      "type": "float",
      "default": 2.5,
      "range": [1, 5],
      "unit": "mm",
      "section": "Expert Mode - Braille Spacing",
      "description": "Spacing between dots within a cell"
    },
    {
      "openscad_name": "braille_x_adjust",
      "web_api_name": "braille_x_adjust",
      "web_ui_label": "X Adjust",
      "type": "float",
      "default": 0.0,
      "range": [-10, 10],
      "unit": "mm",
      "section": "Expert Mode - Braille Spacing",
      "description": "Horizontal adjustment of braille pattern"
    },
    {
      "openscad_name": "braille_y_adjust",
      "web_api_name": "braille_y_adjust",
      "web_ui_label": "Y Adjust",
      "type": "float",
      "default": 0.0,
      "range": [-10, 10],
      "unit": "mm",
      "section": "Expert Mode - Braille Spacing",
      "description": "Vertical adjustment of braille pattern"
    },
    {
      "openscad_name": "rounded_dot_base_diameter",
      "web_api_name": "rounded_dot_base_diameter",
      "web_ui_label": "Rounded dot base diameter (cone base)",
      "type": "float",
      "default": 1.5,
      "range": [0.5, 3],
      "unit": "mm",
      "section": "Expert Mode - Braille Dot Adjustments",
      "subsection": "Embossing Braille Dot Dimensions (Rounded Shape)",
      "description": "Base diameter of rounded dot frustum"
    },
    {
      "openscad_name": "rounded_dot_base_height",
      "web_api_name": "rounded_dot_base_height",
      "web_ui_label": "Rounded dot base height (cone height)",
      "type": "float",
      "default": 0.5,
      "range": [0, 2],
      "unit": "mm",
      "section": "Expert Mode - Braille Dot Adjustments",
      "subsection": "Embossing Braille Dot Dimensions (Rounded Shape)",
      "description": "Height of rounded dot frustum"
    },
    {
      "openscad_name": "rounded_dot_dome_diameter",
      "web_api_name": "rounded_dot_dome_diameter",
      "web_ui_label": "Rounded dome diameter",
      "type": "float",
      "default": 1.0,
      "range": [0.5, 3],
      "unit": "mm",
      "section": "Expert Mode - Braille Dot Adjustments",
      "subsection": "Embossing Braille Dot Dimensions (Rounded Shape)",
