      "section": "Rendering Quality",
      "description": "Number of segments for cone shapes",
      "note": "Affects mesh resolution, not geometry dimensions"
    }
  ],
  
  "removed_parameters": {
    "description": "Parameters removed in version 2.0.0 (card support removed)",
    "parameters": [
      "shape_type",
      "card_width",
      "card_height", 
      "card_thickness"
    ],
    "reason": "Card support permanently removed in favor of cylinder-only operation"
  },
  
  "validation_rules": {
    "description": "Rules for validating parameter consistency between OpenSCAD and web API",
    "checks": [
      {
        "name": "all_openscad_params_mapped",
        "description": "Every OpenSCAD customizer parameter must have a web API equivalent",
        "severity": "error"
      },
      {
        "name": "default_values_match",
        "description": "Default values must be identical across platforms",
        "severity": "error"
      },
      {
        "name": "dropdown_no_duplicates",
        "description": "OpenSCAD dropdown options should not cause duplicate entries in Customizer",
        "severity": "error",
        "check_method": "Verify UI default matches exactly one dropdown option"
      },
      {
        "name": "ranges_match",
        "description": "Value ranges must be identical (where applicable)",
        "severity": "warning"
      },
      {
        "name": "sections_align",
        "description": "Parameter sections/groupings should match UI organization",
        "severity": "warning"
      },
      {
        "name": "types_compatible",
        "description": "Data types must be compatible (string, float, integer, enum)",
        "severity": "error"
      }
    ]
  },
  
  "notes": [
    "Version 2.0.0: Card support removed, cylinder-only operation",
    "Version 2.1.0: Paper thickness preset system added, defaults updated to match web app 0.4mm preset",
    "This mapping is the source of truth for cross-platform validation",
    "Human-readable documentation in PARAMETER_MAPPING.md should be kept in sync",
    "Web API uses snake_case; OpenSCAD uses snake_case (aligned)",
    "UI dropdown labels are human-friendly (e.g., 'Rounded' not 'rounded')",
    "Test system uses lowercase values (e.g., 'rounded', 'positive')",
    "OpenSCAD normalizes both formats in calculated values section",
    "Paper thickness preset controls 24 parameters across spacing, dot dimensions, and cylinder settings",
    "Web UI label 'Card Thickness' is NOT card geometry—it's a parametric memory system for known-good values",
    "Rendering quality parameters affect mesh resolution, not actual geometry dimensions",
    "All spatial units are millimeters (mm)",
    "All angular units are degrees (°)"
  ]
}
