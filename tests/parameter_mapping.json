    },
    {
      "openscad_name": "emboss_dot_height",
      "web_api_name": "emboss_dot_height",
      "web_ui_label": "Dot height",
      "type": "float",
      "default": 0.8,
      "range": [0.3, 2],
      "unit": "mm",
      "section": "Expert Mode - Braille Dot Adjustments",
      "subsection": "Embossing Braille Dot Dimensions (Cone Shape)",
